{
  "name": "strikemap",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:ci": "jest --ci --passWithNoTests",
    "video:setup": "bash scripts/video/setup.sh",
    "video:daily": "bash scripts/video/make-video.sh daily --capture",
    "video:breaking": "bash scripts/video/make-video.sh breaking --capture",
    "video:leadership": "bash scripts/video/make-video.sh leadership --capture",
    "video:weapons": "bash scripts/video/make-video.sh weapons --capture",
    "video:weekly": "bash scripts/video/make-video.sh weekly --capture",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{js,mjs,cjs,json,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@upstash/redis": "^1.36.3",
    "@vercel/analytics": "^1.6.1",
    "mapbox-gl": "^3.9.4",
    "next": "^15.2.0",
    "papaparse": "^5.5.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.2.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "lint-staged": "^16.3.2",
    "postcss": "^8.5.0",
    "prettier": "^3.8.1",
    "puppeteer": "^24.37.5",
    "tailwindcss": "^4.0.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  }
}
